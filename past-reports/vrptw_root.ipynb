    "Inst", "Plan", "PlateauHybridSolver", "RLALNSSolver", "ScheduledHybridSolver",
    "canonical_algo_label", "default_data_path", "default_output_dir",
    "load_datasets", "load_transfer_model", "normalize_algorithm_frame",
    "print_summary_table", "run_benchmark", "run_instance", "run_ortools",
    "smoke_test", "train_transfer_model", "train_transfer_model_within_rc2",
]


# ---------------------------------------------------------------------------
# __main__
# ---------------------------------------------------------------------------

if __name__ == "__main__":
    CFG = Config()

    print("Loading datasets...")
    datasets = load_datasets(CFG.data_path)
    RC1 = datasets.get("rc1", [])
    RC2 = datasets.get("rc2", [])
    if not RC1:
        print(f"⚠️  No data at {CFG.data_path} — check your path.")
        raise SystemExit(1)

    # 1. Smoke test with its OWN short config (does not burn 12h budget)
    print("\n" + "=" * 64)
    print(f"--- Smoke Test on {RC1[0].name} ---")
    smoke_test(RC1[0], seed=CFG.seed)

    # 2. Shared archive across all benchmark phases
    archive = EliteArchive(k=CFG.elite_archive_k)

    # 3. Main benchmark: OR-Tools + ALNS-Base + all Hybrid variants on RC1+RC2
    print("\n" + "=" * 64)
    print("--- Phase 1: Main Benchmark ---")
    RESULT_MAIN = os.path.join(CFG.output_dir, "benchmark_clean.csv")
    # OR-Tools only included if installed; skipped gracefully otherwise
    _algos_main = []
    if ORTOOLS_OK:
        _algos_main.append(ALGO_ORTOOLS)
    _algos_main += [ALGO_ALNS_BASE, ALGO_HYBRID_FIXED, ALGO_HYBRID_RULE, ALGO_HYBRID_DDQN]

    df_main = run_benchmark(
        instances=RC1 + RC2,
        algorithms=_algos_main,
        cfg=CFG,
        result_path=RESULT_MAIN,
        archive=archive,
    )
    print_summary_table(df_main)

    # 4. Transfer learning: train on RC1, apply frozen to RC2
    print("\n" + "=" * 64)
    print("--- Phase 2: RC1 → RC2 Transfer ---")
    transfer_weights_rc1 = load_transfer_model(CFG, label="rc1")
    if transfer_weights_rc1 is None:
        transfer_weights_rc1 = train_transfer_model(RC1, CFG, seed=CFG.seed, label="RC1")

    RESULT_TRANSFER = os.path.join(CFG.output_dir, "benchmark_transfer.csv")
    df_transfer = run_benchmark(
        instances=RC2,
        algorithms=[ALGO_HYBRID_DDQN_TRANSFER],
        cfg=CFG,
        result_path=RESULT_TRANSFER,
        transfer_weights=transfer_weights_rc1,
        archive=archive,
    )

    # 5. Cross-instance transfer within RC2
    print("\n" + "=" * 64)
    print("--- Phase 3: RC2-within Transfer ---")
    transfer_weights_rc2 = load_transfer_model(CFG, label="rc2-src")
    if transfer_weights_rc2 is None:
        transfer_weights_rc2 = train_transfer_model_within_rc2(RC2, CFG, seed=CFG.seed)

    rc2_target = RC2[CFG.rc2_transfer_split:]   # instances not used for training
    RESULT_TRANSFER_RC2 = os.path.join(CFG.output_dir, "benchmark_transfer_rc2.csv")
    df_transfer_rc2 = run_benchmark(
        instances=rc2_target,
        algorithms=[ALGO_HYBRID_DDQN_TRANSFER_RC2],
        cfg=CFG,
        result_path=RESULT_TRANSFER_RC2,
        transfer_weights=transfer_weights_rc2,
        archive=archive,
    )

    # 6. Final combined table
    print("\n" + "=" * 64)
    print("--- Final Combined Results ---")
    df_all = pd.concat([df_main, df_transfer, df_transfer_rc2], ignore_index=True)
    print_summary_table(df_all)

    print("\n--- Elite Archive (best found per instance) ---")
    print(archive.summary())

    print("\n✅  All benchmarks complete!")
