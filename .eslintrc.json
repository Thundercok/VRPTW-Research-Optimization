{
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "no-undef": "warn",
    "no-empty": "warn"
  },
  "globals": {
    "db": "readonly",
    "firebase": "readonly",
    "firebaseService": "readonly",
    "L": "readonly",
    "Chart": "readonly",
    "XLSX": "readonly",
    "firebaseAuth": "readonly"
  }
}
